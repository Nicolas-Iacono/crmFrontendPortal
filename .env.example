# Copiar a .env.local para desarrollo
# Producción: usar las mismas variables en el hosting (Vercel, etc.)

# API Spring — origen del backend (ej. https://xxx.up.railway.app). Podés poner también .../api; se normaliza.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Docker/Railway runtime (SSR): misma URL que arriba si querés separarla del build
# API_URL=https://crminmobiliario-app-production.up.railway.app

# URL pública del portal (producción: https://portal.tuinmo.net)
NEXT_PUBLIC_PORTAL_URL=https://portal.tuinmo.net
